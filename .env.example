# CLAW TERMINAL 环境配置

# ===== 阿里云百炼 API（主要使用）=====
# 从 https://bailian.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 语音播报：AMY 回复是否自动朗读（TTS）
VOICE_ENABLED=true

# ===== DeepSeek API（备选，暂未使用）=====
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenClaw WebSocket 地址
OPENCLAW_WS_URL=ws://127.0.0.1:18789

# OpenClaw WebSocket Token 认证
OPENCLAW_TOKEN=your_openclaw_token_here

# Eagle API 地址
EAGLE_API_URL=http://localhost:41595

# OpenClaw 日志路径（Windows 本地，tail 实时显示）
OPENCLAW_LOG_PATH=C:\Users\zilong_wu\.openclaw\logs\commands.log