{
  "name": "openclaw-terminal",
  "version": "0.1.1",
  "author": "少爷",
  "description": "OpenClaw Terminal - Windows 超级系统助手",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "dev": "vite",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "tsc && vite build && npm run build:electron",
    "start": "npm run build:electron && concurrently \"npm run dev\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "electron:dev": "npm run build:electron && concurrently \"npm run dev\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "electron:build:linux": "npm run build && electron-builder --linux --x64",
    "electron:build:all": "npm run build && electron-builder --win --mac --linux --x64"
  },
  "build": {
    "appId": "com.openclaw.terminal",
    "productName": "OCT OpenClaw Terminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/float.html",
      "electron/code-window.html",
      "electron/terminal-window.html",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "OCT-Setup-v${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "artifactName": "OCT-${version}-Mac-${arch}.dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "OCT-${version}-Linux-${arch}.${ext}",
      "category": "Development",
      "synopsis": "OpenClaw Terminal - AI Desktop Assistant"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OCT Terminal"
    },
    "npmRebuild": true,
    "nativeRebuilder": "legacy"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "dotenv": "^16.3.1",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "ws": "^8.16.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "decode-ico": "^0.4.1",
    "icon-gen": "^5.0.0",
    "javascript-obfuscator": "^5.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "wait-on": "^7.2.0"
  }
}
